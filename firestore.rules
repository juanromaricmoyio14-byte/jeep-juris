rules_version = '2';

// JEEP JURIS — Firestore Security Rules
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check uses a Firebase Custom Claim `admin: true`.
    // Set it from a trusted environment (Cloud Function / Admin SDK):
    //   admin.auth().setCustomUserClaims(uid, { admin: true })
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Feedback submissions: anyone signed-in may write; only admins may read.
    match /feedbacks/{doc} {
      allow create: if request.auth != null
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 2000
                    && (!('userId' in request.resource.data)
                        || request.resource.data.userId == request.auth.uid)
                    && (!('userEmail' in request.resource.data)
                        || request.resource.data.userEmail == request.auth.token.email)
                    && (!('name' in request.resource.data)
                        || (request.resource.data.name is string
                            && request.resource.data.name.size() <= 100))
                    && (!('email' in request.resource.data)
                        || (request.resource.data.email is string
                            && request.resource.data.email.size() <= 255))
                    && (!('type' in request.resource.data)
                        || request.resource.data.type in ['bug', 'suggestion', 'compliment']);
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Per-user consultation history: only the owning user can read/write.
    match /users/{uid}/consultations/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
